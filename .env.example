# ============================================================
# انسخ هذا الملف إلى .env وعدّل القيم
# cp .env.example .env
# ============================================================

# Neon PostgreSQL — Pooled (runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true&connect_timeout=30"

# Neon PostgreSQL — Direct (migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require&connect_timeout=30"

# Supabase Storage (for image uploads — optional)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
